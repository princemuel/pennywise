---
import Content from "@/content/partials/projects.md";

import type { MetadataConfig } from "@/lib/metadata";

import Markdown from "@/components/content/markdown.astro";
import Layout from "@/layouts/layout.astro";

const metadata = {
  title: "Projects",
  description:
    "A list of projects I've worked on, or am currently working on. Mostly web development",
} satisfies MetadataConfig;
---

<Fragment>
  <Layout metadata={metadata}>
    <Fragment slot="metadata"></Fragment>
    <Fragment slot="opengraph"></Fragment>
    <Fragment>
      <Markdown>
        <h1 id="headline">{metadata.title}</h1>
        <Content />
      </Markdown>
    </Fragment>
  </Layout>
</Fragment>
