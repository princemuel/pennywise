---
import { Content } from "@/content/partials/about.md";

import type { MetadataConfig } from "@/lib/metadata";

import Markdown from "@/components/content/markdown.astro";
import Layout from "@/layouts/layout.astro";

const metadata = {
  // title: htmlTitle("Projects", "%title% | %brand%", { brand: "Prince Muel" }),
  title: "About Me",
  description:
    "A list of projects I've worked on, or am currently working on. Mostly web development",
} satisfies MetadataConfig;
---

<Fragment>
  <Layout metadata={metadata}>
    <Fragment slot="opengraph"></Fragment>
    <Fragment slot="metadata">
      <meta property="profile:first_name" content="Samuel" />
      <meta property="profile:last_name" content="Chukwuzube" />
      <meta property="profile:username" content="princemuel" />
      <meta property="profile:gender" content="male" />
    </Fragment>

    <Markdown>
      <h1 id="headline">{metadata.title}</h1>
      <Content />
    </Markdown>
  </Layout>
</Fragment>
