---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"article">;

const { ...rest } = Astro.props;
---

<article
  id="article"
  aria-labelledby="headline"
  class:list={[
    "prose prose-gray 3xl:prose-lg dark:prose-invert",
    "max-w-none **:[.expressive-code_+_.expressive-code]:mt-12",
  ]}
  {...rest}
>
  <slot />
</article>
