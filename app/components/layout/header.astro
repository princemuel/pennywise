---
import { Image } from "astro:assets";

import { avatar } from "@/assets/media/images";

import Frame from "@/components/layout/frame.astro";
import Link from "@/components/primitives/link.astro";
import Routes from "@/components/widgets/routes.astro";
import ThemePicker from "@/components/widgets/theme-picker.astro";
---

<header class="sticky top-0 z-50 divide-gray-200 bg-white max-sm:divide-y">
  <Frame>
    <div class="flex items-center justify-between py-5 sm:py-6">
      <Link
        href="/"
        class="flex size-8 items-center justify-center overflow-hidden rounded-full border-2 border-gray-200"
      >
        <Image width={32} height={32} alt="Prince Muel" src={avatar} loading="eager" />
        <span class="sr-only">Home</span>
      </Link>

      <div class="max-sm:hidden">
        <Routes />
      </div>

      <ThemePicker />
    </div>
  </Frame>

  <Frame class="bg-gray-50 py-1 shadow-2xs sm:hidden">
    <Routes />
  </Frame>
</header>
