---
import { DateTimeFormatter } from "@/helpers/date-formatter";
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"time">;

const { datetime, ...attrs } = Astro.props;

const fmt = new DateTimeFormatter();
const date = new Date(datetime ?? Date.now());
---

<time datetime={fmt.toISOString(date)} {...attrs}>
  {fmt.format(date)} &copy;
</time>
