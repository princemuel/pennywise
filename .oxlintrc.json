{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "typescript", "unicorn", "promise", "node", "oxc", "jsx-a11y"],
  "env": {
    "esnext": true,
    "browser": true,
    "node": true,
    "shared-node-browser": true
  },
  "globals": {
    "Astro": "readonly"
  },
  "categories": {
    "correctness": "deny",
    "nursery": "warn",
    "pedantic": "warn",
    "perf": "warn",
    "restriction": "allow",
    "style": "warn",
    "suspicious": "warn"
  },
  "rules": {
    "curly": "allow",
    "sort-imports": "allow",
    "sort-keys": "allow",
    "no-magic-numbers": "allow",
    "no-ternary": "allow",
    "no-anonymous-default-export": "allow",
    "require-await": "allow",
    "yoda": "allow",
    "import/no-namespace": "allow",
    "import/max-dependencies": "allow",
    "import/exports-last": "allow",
    "import/group-exports": "allow",
    "import/no-unassigned-import": "allow",
    "eslint/max-nested-callbacks": ["warn", 10],
    "eslint/max-depth": "allow",
    // "eslint/no-duplicate-imports": "allow",
    "eslint/max-lines-per-function": [
      "warn",
      {
        "max": 72,
        "skipBlankLines": false,
        "skipComments": false,
        "IIFEs": true
      }
    ],
    "unicorn/filename-case": [
      "error",
      {
        "cases": {
          "camelCase": false,
          "pascalCase": false,
          "snakeCase": false,
          "kebabCase": true
        }
      }
    ],
    "unicorn/no-null": "allow"
  },
  "ignorePatterns": ["dist", ".astro", ".netlify", "**/ignored/*", "**/local/*"],
  "settings": {
    "jsx-a11y": {
      "components": {
        "Link": "a"
      }
    }
  }
}
