RUST_LOG=info
RUST_BACKTRACE=0
SQLX_OFFLINE=0

DATABASE_URL=postgresql://user:password@host:5432/dbname

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=dbname

PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=password

APP_ENVIRONMENT=local

APP_APPLICATION__HOST=127.0.0.1
APP_APPLICATION__PORT=8080
APP_APPLICATION__BASE_URL=http://127.0.0.1:8080
APP_APPLICATION__TIMEOUT=10

APP_DATABASE__HOST=localhost
APP_DATABASE__PORT=5432
APP_DATABASE__NAME=dbname
APP_DATABASE__USERNAME=user
APP_DATABASE__PASSWORD=password
APP_DATABASE__URL=postgresql://user:password@host:5432/dbname
APP_DATABASE__REQUIRE_SSL=false
APP_DATABASE__POOL_MIN_CONNECTIONS=1
APP_DATABASE__POOL_MAX_CONNECTIONS=5
APP_DATABASE__POOL_ACQUIRE_TIMEOUT_MS=2000
APP_DATABASE__POOL_IDLE_TIMEOUT_MS=600000
APP_DATABASE__POOL_MAX_LIFETIME_MS=1800000

APP_REDIS__HOST=127.0.0.1
APP_REDIS__PORT=6379

APP_AUTH__JWT_SECRET=
APP_AUTH__HMAC_SECRET=
APP_AUTH__JWT_EXPIRY_SECS=3600

APP_OAUTH__GOOGLE__CLIENT_ID=
APP_OAUTH__GOOGLE__CLIENT_SECRET=
APP_OAUTH__GOOGLE__REDIRECT_PATH=/auth/google/callback

APP_OAUTH__GITHUB__CLIENT_ID=
APP_OAUTH__GITHUB__CLIENT_SECRET=
APP_OAUTH__GITHUB__REDIRECT_PATH=/auth/github/callback
