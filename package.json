{
	"name": "pennywise",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prebuild": "pnpm iconify",
		"predev": "pnpm iconify",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"iconify": "./scripts/iconify.sh ./src/assets/media/icons",
		"format": "prettier --write .",
		"db:start": "docker compose up",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/public-sans": "^5.2.7",
		"@poppanator/sveltekit-svg": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.3.0",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/node": "^25",
		"better-auth": "~1.6.10",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"postgres": "^3.4.9",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"sveltekit-flash-message": "^2.4.6",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.12",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"dependencies": {
		"formsnap": "^2.0.1",
		"temporal-polyfill": "^0.3.2",
		"uuid": "^14.0.0",
		"zod": "^4.4.3"
	},
	"packageManager": "pnpm@11.1.0"
}
